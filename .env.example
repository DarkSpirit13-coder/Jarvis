# Environment configuration for a local JARVIS deployment.
APP_NAME=JARVIS
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
ENABLE_OPENAPI=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@postgres:5432/jarvis
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
TOOL_TIMEOUT_SECONDS=20
TOOL_RETRIES=1
TERMINAL_TIMEOUT_SECONDS=10
WORKSPACE_ROOT=.
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
